generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "public"]
}

model Profile {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  email                 String?              @unique
  phoneNumber           String?              @map("phone_number")
  profileImage          String?              @map("profile_image")
  loyaltyPoints         Int                  @default(0) @map("loyalty_points")
  notifications_enabled Boolean              @default(true)
  notif_order_updates   Boolean              @default(true)
  notif_promotions      Boolean              @default(true)
  notif_loyalty_updates Boolean              @default(true)
  notif_newsletter      Boolean              @default(false)
  notif_sms             Boolean              @default(true)
  notif_email           Boolean              @default(true)
  notif_push            Boolean              @default(true)
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  authUserId            String?              @map("auth_user_id")
  phone_verified_at     DateTime?            @db.Timestamptz(6)
  email_verified_at     DateTime?            @db.Timestamptz(6)
  addresses             Address[]
  loyalty_activities    loyalty_activities[]
  orders                Order[]
  payment_methods       payment_methods[]
  support_tickets       support_tickets[]
  user_notifications    user_notifications[]
  user_settings         user_settings?

  @@map("profiles")
  @@schema("public")
}

model Address {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId   String   @map("profile_id") @db.Uuid
  name        String
  phoneNumber String?  @map("phone_number")
  address     String
  city        String?
  state       String?
  pincode     String?
  type        String   @default("home")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([profileId, isDefault], map: "idx_addresses_profile_default")
  @@index([profileId], map: "idx_addresses_profile_id")
  @@map("addresses")
  @@schema("public")
}

model Order {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber         String               @unique @map("order_number")
  profileId           String               @map("profile_id") @db.Uuid
  status              String               @default("confirmed")
  totalAmount         Decimal              @map("total_amount") @db.Decimal(12, 2)
  paymentStatus       String               @default("pending") @map("payment_status")
  paymentMethod       String               @map("payment_method")
  trackingNumber      String?              @unique @map("tracking_number")
  estimatedDelivery   DateTime?            @map("estimated_delivery") @db.Timestamptz(6)
  shippingName        String               @map("shipping_name")
  shippingPhone       String?              @map("shipping_phone")
  shippingAddress     String               @map("shipping_address")
  shippingCity        String?              @map("shipping_city")
  shippingState       String?              @map("shipping_state")
  shippingPincode     String?              @map("shipping_pincode")
  deliverySlot        String?              @map("delivery_slot")
  pointsEarned        Int                  @default(0) @map("points_earned")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  processingVideoUrl  String?              @map("processing_video_url")
  deliveryPersonName  String?              @map("delivery_person_name")
  deliveryPersonPhone String?              @map("delivery_person_phone")
  isDeliveryReached   Boolean              @default(false) @map("is_delivery_reached")
  loyalty_activities  loyalty_activities[]
  events              OrderEvent[]
  items               OrderItem[]
  profile             Profile              @relation(fields: [profileId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt(sort: Desc)], map: "idx_orders_created_at")
  @@index([orderNumber], map: "idx_orders_order_number")
  @@index([profileId], map: "idx_orders_profile_id")
  @@index([trackingNumber], map: "idx_orders_tracking_number")
  @@map("orders")
  @@schema("public")
}

model OrderItem {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  productId    String?  @map("product_id")
  productName  String   @map("product_name")
  productImage String?  @map("product_image")
  quantity     Int
  price        Decimal  @db.Decimal(12, 2)
  weight       String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([orderId], map: "idx_order_items_order_id")
  @@map("order_items")
  @@schema("public")
}

model OrderEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String   @map("order_id") @db.Uuid
  status      String
  description String
  location    String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([orderId, createdAt], map: "idx_order_events_created_at")
  @@index([orderId], map: "idx_order_events_order_id")
  @@map("order_events")
  @@schema("public")
}

